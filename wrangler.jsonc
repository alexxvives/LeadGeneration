{
  // Cloudflare Workers deploy config for Leadify (via @opennextjs/cloudflare).
  // Local `npm run dev` does NOT use this — it runs plain Next.js in demo mode
  // (JSON store, zero keys). Use `npm run cf:preview` to exercise D1 locally.
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "leadgeneration",
  "main": ".open-next/worker.js",
  "compatibility_date": "2026-07-01",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  },
  "d1_databases": [
    {
      "binding": "DB",
      // CF resource name (do not rename without migrating the D1 database).
      "database_name": "lodestar-prod",
      "database_id": "f990d480-83aa-4123-8979-e47d11347069",
      "migrations_dir": "migrations"
    }
  ],
  // Optional LLM for lead blurbs + default pitch (Llama 3.1 via Workers AI).
  // Pitch generate never invents heuristic copy — needs AI or manual write.
  "ai": {
    "binding": "AI"
  }
}
