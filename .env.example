# ─────────────────────────────────────────────────────────────
# Leadify — environment variables
# Copy this file to `.env.local` and fill in what you have.
# EVERYTHING is optional: with no keys, the app runs in demo mode
# (sample leads + simulated sends) so the whole UI still works.
# Restart `npm run dev` after changing these.
# ─────────────────────────────────────────────────────────────

# ── Search / enrichment (pick one; Firecrawl preferred) ──
# Firecrawl: live web search + full-page scrape. https://firecrawl.dev
FIRECRAWL_API_KEY=

# Exa: alternative live search provider. https://exa.ai
EXA_API_KEY=

# Max leads discovered per search run (default 12)
MAX_LEADS_PER_RUN=500

# ── Email sending ──
# Recommended Easy path: Resend OR Maileroo (BYO key in Settings — ADR 0011).
# Platform keys below are for local/dev demos and product mail only.
# Resend: https://resend.com — verify domain, paste API key in Settings or here.
RESEND_API_KEY=

# Fallback: any SMTP server (Maileroo SMTP, Amazon SES, Postfix, etc.)
# Only used if no Resend/Maileroo workspace key and no RESEND_API_KEY.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ── Email verification (Maileroo Verify = Zeruh API) ──
# Separate from Maileroo *send* and from Resend/Gmail. Checks addresses are
# deliverable before/at send (list hygiene). Demo works without this key.
#
# How to get MAILEROO_VERIFY_API_KEY:
#   1. Create a free account at https://maileroo.com (or https://zeruh.com)
#   2. Open Email Verification / Zeruh (SSO from the Maileroo dashboard)
#   3. Create an API key → paste below (and as a Wrangler secret in prod)
# Alias ZERUH_API_KEY accepts the same value if you prefer that name.
MAILEROO_VERIFY_API_KEY=
# Alias (same value): ZERUH_API_KEY=
#
# Preferred verify provider (100 free credits/day with phone-verified account).
# When set, used instead of Zeruh above. Credits show in the Verifies bar.
MYEMAILVERIFIER_API_KEY=

# ── Sending identity & compliance (used in every email footer) ──
OUTREACH_FROM_NAME="Your Name"
OUTREACH_FROM_EMAIL=you@yourdomain.com
OUTREACH_REPLY_TO=
# Physical mailing address is required by CAN-SPAM for commercial email.
OUTREACH_PHYSICAL_ADDRESS="123 Placeholder St, Your City, ST 00000"
# Outbound sends per rolling minute (rate limit / deliverability guard).
SEND_RATE_PER_MINUTE=5

# ── Persistence (Cloudflare D1 / SQLite) ──
# D1 is accessed via a Workers binding — NOT an env var — so there is nothing
# to set here for the database. In production (Workers + OpenNext), the D1
# binding is declared in wrangler.jsonc and injected at request time. In local
# dev and demo mode, the app automatically uses the JSON file store (data/db.json).
# See src/lib/db/d1-store.ts, migrations/0001_init.sql, and
# docs/decisions/0005-switch-to-d1-auth-js.md.

# ── Auth (Auth.js v5) ──
# LEAVE BLANK for local dev: with no AUTH_SECRET the studio is open (no login)
# and usage is unmetered — zero-key demo mode (constitution Article I.2).
# SET IN PRODUCTION (as a Wrangler secret): this is the switch that ENFORCES
# auth + metering. Generate with: npx auth secret
AUTH_SECRET=
# Magic-link login emails use RESEND_API_KEY (same key as outreach — no extra var needed).
# Local demo mode uses a password form instead (any email works, no key required).
# Base URL of the app (used for magic-link, Stripe, and Gmail OAuth redirect).
# Local: http://localhost:3000
# Production (Wrangler secret): https://leadgeneration.alexxvives.workers.dev
NEXTAUTH_URL=http://localhost:3000
# Platform admin (plan override / credit reset). Defaults shown; rotate password in prod.
ADMIN_EMAIL=admin@tryhermesmail.com
ADMIN_PASSWORD=password
# OAuth providers (optional) — Auth.js *login* only (not mailbox send).
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=

# ── Pro mailbox send (ADR 0010) — Gmail OAuth for outreach ──
# Separate from login. Google Cloud → OAuth client (Web) with redirect:
#   {NEXTAUTH_URL}/api/mailbox/google/callback
# Scopes: gmail.send (+ openid email for identity). Leave blank = Pro connect disabled.
GMAIL_OAUTH_CLIENT_ID=
GMAIL_OAUTH_CLIENT_SECRET=

# ── Billing (Stripe) ──
# Server-side only — never exposed to the client. Leave blank in demo mode.
# Full guide: docs/stripe-setup.md (Starter $39 / Pro $89 / Agency $199).
STRIPE_SECRET_KEY=
# Webhook signing secret (Dashboard → Webhooks → endpoint → Signing secret).
# Endpoint: /api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=
# Signing secret for Resend webhooks (Svix). Optional in local demo.
# Dashboard → Webhooks → signing secret. Endpoint: /api/webhooks/resend
RESEND_WEBHOOK_SECRET=

# Optional shared secret for Maileroo delivery webhooks.
# Dashboard → Events / Webhooks → URL: /api/webhooks/maileroo
# Send header X-Maileroo-Secret (or Authorization: Bearer …) matching this value.
MAILEROO_WEBHOOK_SECRET=

# One monthly recurring Price ID per paid plan (create in the Stripe Dashboard).
STRIPE_STARTER_PRICE_ID=
STRIPE_PRO_PRICE_ID=
STRIPE_AGENCY_PRICE_ID=

# ── Cloudflare Turnstile (bot check on the signup/login form) ──
# Production only. When the SITE key is set, the /login form renders the widget
# and the token is verified server-side. Unset → local dev is unaffected.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ── Optional LLM (pitch + blurbs) ──
# Production: Workers AI binding in wrangler.jsonc (no keys). Local/dev:
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_API_TOKEN=
# Or free-tier alternatives when Workers AI isn’t available.
# Also set these as Wrangler secrets on the Worker if you want the cascade
# in production (see docs/cloudflare-secrets.md — deploy does NOT wipe them):
# GROQ_API_KEY=
# GEMINI_API_KEY=
# Without AI, write the pitch manually (no heuristic fake pitch).

# ── Smoke test (optional) ──
# When auth is enforced, set this so `npm run smoke` can bypass auth via the
# `x-smoke-key` header. Leave blank in local dev (auth is not enforced there).
SMOKE_API_KEY=

# ── Persistence (Cloudflare D1 / SQLite) ──
# D1 is accessed via a Workers binding (name: DB in wrangler.jsonc) — NOT an env
# var. In production the binding is injected at request time
# (getCloudflareContext().env.DB). In local `npm run dev` there is no binding →
# the JSON file store (data/db.json) is used. See src/lib/cf.ts.

# ── Deploy target (Cloudflare Workers via @opennextjs/cloudflare) ──
# Configured in wrangler.jsonc. Secrets above are set with `wrangler secret put`.
# The app must still run locally with `npm run dev` — constitution Article I.2.
# See docs/decisions/0004-cloudflare-opennext-deploy.md and the README Deploy section.

# ── Feature flags ──
# Contact-form automation is a DEMO-ONLY stub and OFF by default. Even when
# "true" it only simulates a submission. Do NOT enable for real use without a
# ToS / legal review. Keep a human in the loop.
ENABLE_CONTACT_FORM_AUTOMATION=false
