# ─────────────────────────────────────────────────────────────
# Lodestar — environment variables
# Copy this file to `.env.local` and fill in what you have.
# EVERYTHING is optional: with no keys, the app runs in demo mode
# (sample leads + simulated sends) so the whole UI still works.
# Restart `npm run dev` after changing these.
# ─────────────────────────────────────────────────────────────

# ── Search / enrichment (pick one; Firecrawl preferred) ──
# Firecrawl: live web search + full-page scrape. https://firecrawl.dev
FIRECRAWL_API_KEY=

# Exa: alternative live search provider. https://exa.ai
EXA_API_KEY=

# Max leads discovered per search run (default 12)
MAX_LEADS_PER_RUN=12

# ── Email sending (pick ONE transport) ──
# See docs/email-providers.md for a cost/quality comparison + recommendation.
#
# Option A — Resend. Best developer experience. https://resend.com
RESEND_API_KEY=

# Option B — SMTP via Nodemailer. Works with Maileroo (lowest cost, 3,000/mo
# free), Amazon SES (cheapest at scale), Postmark, etc. Leave blank if using Resend.
#   Maileroo:   SMTP_HOST=smtp.maileroo.com  SMTP_PORT=587
#   Amazon SES: SMTP_HOST=email-smtp.<region>.amazonaws.com  SMTP_PORT=587
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ── Sending identity & compliance (used in every email footer) ──
OUTREACH_FROM_NAME="Your Name"
OUTREACH_FROM_EMAIL=you@yourdomain.com
OUTREACH_REPLY_TO=
# Physical mailing address is required by CAN-SPAM for commercial email.
OUTREACH_PHYSICAL_ADDRESS="123 Placeholder St, Your City, ST 00000"
# Outbound sends per rolling minute (rate limit / deliverability guard).
SEND_RATE_PER_MINUTE=5

# ── Persistence (Cloudflare D1 / SQLite) ──
# D1 is accessed via a Workers binding — NOT an env var — so there is nothing
# to set here for the database. In production (Workers + OpenNext), the D1
# binding is declared in wrangler.jsonc and injected at request time. In local
# dev and demo mode, the app automatically uses the JSON file store (data/db.json).
# See src/lib/db/d1-store.ts, migrations/0001_init.sql, and
# docs/decisions/0005-switch-to-d1-auth-js.md.

# ── Auth (Auth.js) ──
# Set these in Phase 1 (Auth + workspaces). Leave blank for now.
# AUTH_SECRET is required by Auth.js (generate with: npx auth secret).
AUTH_SECRET=
# OAuth providers (optional; add whichever you want in Phase 1).
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=

# ── Deploy target (Cloudflare Workers via @opennextjs/cloudflare) ──
# Deployment is configured in wrangler.jsonc / CI, not via runtime env vars.
# No Cloudflare secrets are read by the app itself. The app must still run
# locally with `npm run dev` — constitution Article I.2.
# See docs/decisions/0004-cloudflare-opennext-deploy.md.

# ── Feature flags ──
# Contact-form automation is a DEMO-ONLY stub and OFF by default. Even when
# "true" it only simulates a submission. Do NOT enable for real use without a
# ToS / legal review. Keep a human in the loop.
ENABLE_CONTACT_FORM_AUTOMATION=false
